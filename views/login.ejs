<!DOCTYPE html>
<html>

<head>
    <title>Login - Productivity Hub</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet"> <!--Helps with icons which are used (bibi)-->
    <link href="/style.css" rel="stylesheet">
</head>

<body class="bg-gradient d-flex align-items-center min-vh-100">
    <div class="container">
        <div class="row justify-content-center"> <!--Centers the login card-->
            <div class="col-md-5">
                <div class="card shadow-lg border-0">
                    <div class="card-body p-5">
                        <div class="text-center mb-4">
                            <i class="bi bi-shield-lock-fill text-primary display-4"></i>
                            <h2 class="fw-bold">Login</h2>
                            <p class="text-muted">Sign in to manage your productivity</p>
                        </div>

                        <% if (error) { %>
                        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            <%= error %>
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                        <% } %>

                        <form action="/login" method="POST">
                            <div class="mb-4">
                                <label class="form-label fw-bold">Username</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light"><i class="bi bi-person"></i></span>
                                    <input type="text" name="username" class="form-control form-control-lg bg-light" placeholder="Username" required>
                                </div>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-bold">Password</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light"><i class="bi bi-key"></i></span>
                                    <input type="password" name="password" class="form-control form-control-lg bg-light" placeholder="Password" required>
                                </div>
                                <div class="form-text mt-2">
                                    <i class="bi bi-info-circle"></i> Passwords are encrypted using <strong>Bcrypt</strong>. 
                                </div>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-bold">Security Challenge</label>
                                <div id="loginCaptcha" class="alert alert-primary mb-3 fw-bold fs-5 text-center py-3 border-0 shadow-sm">
                                    <span class="ms-2">Generating challenge...</span>
                                </div>
                                <input type="number" name="captcha" class="form-control form-control-lg text-center" placeholder="Enter answer" required>
                            </div>

                            <button type="submit" class="btn btn-primary btn-lg w-100 shadow-sm">
                                <i class="bi bi-box-arrow-in-right me-2"></i>Enter Dashboard
                            </button>
                        </form>

                        <hr class="my-4">

                        <div class="text-center">
                            <p class="small text-muted mb-3">Want to see how this was built?</p>
                            <a href="/wiki" class="btn btn-outline-secondary w-100">
                                <i class="bi bi-book me-2"></i>View Wiki 
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Fetching Dynamic Content from the Server for Captcha
        fetch('/api/login-captcha')
            .then(r => r.json()) //converting response to json
            .then(data => {
                const captchaContainer = document.getElementById('loginCaptcha');
                captchaContainer.innerHTML = `<i class="me-2"></i>${data.question}`; // Display the captcha question
            }) 
            .catch(err => {
                console.error('Captcha fetch error:', err);
                document.getElementById('loginCaptcha').innerText = "Error loading captcha";
            });
    </script>
</body>

</html>